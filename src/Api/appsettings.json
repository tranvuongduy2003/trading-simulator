{
  "ConnectionStrings": {
    "Trading": "Host=localhost;Port=5432;Database=trading;Username=postgres;Password=postgres",
    "Cache": "localhost:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Session": {
    "CookieName": "TradingSimulator.Session",
    "ExpirationHours": 24
  },
  "Trading": {
    "InitialVirtualCash": 100000,
    "PortfolioResetCooldownMinutes": 1440,
    "IncomingOrderChannelCapacity": 1000,
    "SimulatedLiquidity": {
      "Enabled": true,
      "RefreshIntervalSeconds": 30
    }
  }
}
