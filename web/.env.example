# Copy to web/.env — standalone `yarn dev` (do not run Vite on port 5000 while AppHost `web` is up).
#
# Pinned ports (src/AppHost/AppHost.cs):
#   API HTTPS  https://localhost:8000
#   API HTTP   http://localhost:8001
#   Web (Vite) https://localhost:5000 when VITE_DEV_HTTPS=1
#
# API CORS (src/Api/appsettings.Development.json) allows https://localhost:5000.
# Prefer HTTPS API + HTTPS Vite below. Aspire injects VITE_API_URL when you use AppHost.
VITE_API_URL=https://localhost:8000
VITE_DEFAULT_SYMBOL=AAPL

# Optional: serve Vite over HTTPS (run `dotnet dev-certs https --trust` first)
# VITE_DEV_HTTPS=1

# Alternative: HTTP API — only if you also add http://localhost:5000 to Cors:AllowedOrigins
# VITE_API_URL=http://localhost:8001
