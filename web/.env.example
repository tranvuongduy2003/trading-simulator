# Copy to web/.env — used when running `yarn dev` (frontend not started by AppHost).
#
# Default Vite is HTTP on port 5000; use the API HTTP port to avoid mixed-content blocking.
VITE_API_URL=http://localhost:8001

# Optional: HTTPS Vite + HTTPS API (run `dotnet dev-certs https --trust` first)
# VITE_DEV_HTTPS=1
# VITE_API_URL=https://localhost:8000
