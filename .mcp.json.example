{
  "context7": {
    "command": "cmd",
    "args": [
      "/c",
      "npx",
      "-y",
      "@upstash/context7-mcp@latest"
    ]
  },
  "aspire": {
    "command": "aspire",
    "args": [
      "agent",
      "mcp"
    ]
  },
  "postgres": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-postgres",
      "postgresql://postgres:YOUR_PASSWORD@localhost:5432/trading?sslmode=disable"
    ]
  },
  "filesystem": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-filesystem",
      "/absolute/path/to/trading-simulator"
    ]
  }
}
